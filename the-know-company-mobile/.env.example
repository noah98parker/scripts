# ── Supabase ────────────────────────────────────────────────────────────────
# Create a FREE project at https://supabase.com
# Project Settings → API → Project URL and anon/public key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Google Places API (optional) ────────────────────────────────────────────
# For richer garage data (real names, ratings, hours).
# Get a key at https://console.cloud.google.com → Enable "Places API"
# Add to Maps > Credentials; restrict to your bundle ID for production.
# Users can also enter this directly in the app's Account → Settings screen.
GOOGLE_PLACES_KEY=AIzaSy...
