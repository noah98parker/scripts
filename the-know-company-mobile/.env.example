# ── Supabase ────────────────────────────────────────────────────────────────
# Create a FREE project at https://supabase.com
# Project Settings → API → Project URL and anon/public key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Google Places API (optional) ────────────────────────────────────────────
# For richer garage data (real names, ratings, hours).
# Get a key at https://console.cloud.google.com → Enable "Places API"
# Add to Maps > Credentials; restrict to your bundle ID for production.
# Users can also enter this directly in the app's Account → Settings screen.
GOOGLE_PLACES_KEY=AIzaSy...

# ── Sign Decoder (AI camera feature) ────────────────────────────────────────
# Point your camera at a parking sign → AI reads it in plain English.
# Set this to your Vercel deployment URL (no trailing slash).
# The Vercel app must have ANTHROPIC_API_KEY set in its environment variables.
# Get your Vercel URL from: https://vercel.com/dashboard → your project
EXPO_PUBLIC_API_URL=https://the-know-company.vercel.app
