# ── Vercel Environment Variables ─────────────────────────────────────────────
# Set these in Vercel → Project → Settings → Environment Variables.
# They are server-side only — end users never see or need these keys.

# Anthropic API key — powers the AI Sign Decoder (📸 camera feature)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Places API key — adds real garage names, ratings, and hours
# Get yours at: https://console.cloud.google.com → Enable "Places API"
# Restrict to your Vercel deployment domain for production.
GOOGLE_PLACES_KEY=AIzaSy...
